generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  LEARNER
  ADMIN
  ORG_ADMIN
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum CertificateStatus {
  VALID
  REVOKED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ExamAttemptMode {
  OFFICIAL
  PRACTICE
}

model User {
  id             String            @id @default(cuid())
  email          String            @unique
  phone          String?
  passwordHash   String?
  name           String
  imageUrl       String?
  role           Role              @default(LEARNER)
  locale         String            @default("fr")
  organizationId String?
  organization   Organization?     @relation(fields: [organizationId], references: [id])
  enrollments    Enrollment[]
  certificates   CertificateIssued[]
  examAttempts   ExamAttempt[]
  payments       Payment[]
  lessonCompletions LessonCompletion[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  type         String
  contactEmail String
  seats        Int      @default(0)
  members      User[]
  createdAt    DateTime @default(now())
}

model CertificationLevel {
  id             String           @id @default(cuid())
  slug           String           @unique
  nameFr         String
  nameEn         String
  rank           Int              @default(0)
  createdAt      DateTime         @default(now())
  courses        Course[]
  certifications Certification[]
  examQuestions  ExamQuestion[]
}

model Course {
  id             String          @id @default(cuid())
  slug           String          @unique
  titleFr        String
  titleEn        String
  descriptionFr  String
  descriptionEn  String
  levelId        String
  level          CertificationLevel @relation(fields: [levelId], references: [id])
  price          Decimal         @db.Decimal(10, 2)
  currency       String          @default("USD")
  imageUrl       String?
  published      Boolean         @default(false)
  modules        Module[]
  exams          Exam[]
  examCategories ExamCategory[]
  enrollments    Enrollment[]
  certifications Certification[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Module {
  id       String   @id @default(cuid())
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  titleFr  String
  titleEn  String
  order    Int
  lessons  Lesson[]
}

model Lesson {
  id          String  @id @default(cuid())
  moduleId    String
  module      Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  titleFr     String
  titleEn     String
  contentType String
  contentUrl  String?
  bodyFr      String?
  bodyEn      String?
  order       Int
  durationMin Int?
  completions LessonCompletion[]
}

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  courseId    String
  course      Course           @relation(fields: [courseId], references: [id])
  status      EnrollmentStatus @default(ACTIVE)
  progressPct Int              @default(0)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  lessonCompletions LessonCompletion[]

  @@unique([userId, courseId])
}

model LessonCompletion {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  lessonId     String
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  completedAt  DateTime   @default(now())

  @@unique([userId, lessonId, enrollmentId])
}

model ExamCategory {
  id           String                    @id @default(cuid())
  courseId     String
  course       Course                    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  nameFr       String
  nameEn       String
  slug         String
  requirements ExamCategoryRequirement[]
  questions    ExamQuestion[]

  @@unique([courseId, slug])
}

model Exam {
  id             String                    @id @default(cuid())
  courseId       String
  course         Course                    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  titleFr        String
  titleEn        String
  passingScore   Int                       @default(70)
  durationMin    Int                       @default(60)
  maxAttempts    Int                       @default(3)
  isPractice     Boolean                   @default(false)
  questionCount  Int?
  attempts       ExamAttempt[]
  questions      ExamQuestion[]
  categoryReqs   ExamCategoryRequirement[]
}

model ExamCategoryRequirement {
  id         String       @id @default(cuid())
  examId     String
  exam       Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  categoryId String
  category   ExamCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  minScore   Int

  @@unique([examId, categoryId])
}

model ExamQuestion {
  id         String             @id @default(cuid())
  examId     String
  exam       Exam               @relation(fields: [examId], references: [id], onDelete: Cascade)
  levelId    String
  level      CertificationLevel @relation(fields: [levelId], references: [id])
  categoryId String
  category   ExamCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  promptFr   String
  promptEn   String
  order      Int                @default(0)
  active     Boolean            @default(true)
  choices    ExamChoice[]
  answers    ExamAttemptAnswer[]
}

model ExamChoice {
  id         String              @id @default(cuid())
  questionId String
  question   ExamQuestion        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  labelFr    String
  labelEn    String
  isCorrect  Boolean             @default(false)
  order      Int                 @default(0)
  answers    ExamAttemptAnswer[]
}

model ExamAttempt {
  id             String              @id @default(cuid())
  examId         String
  exam           Exam                @relation(fields: [examId], references: [id])
  userId         String
  user           User                @relation(fields: [userId], references: [id])
  mode           ExamAttemptMode     @default(OFFICIAL)
  score          Int                 @default(0)
  passed         Boolean             @default(false)
  startedAt      DateTime            @default(now())
  endsAt         DateTime
  finishedAt     DateTime?
  timedOut       Boolean             @default(false)
  categoryScores Json?
  questionIds    String[]
  answers        ExamAttemptAnswer[]
  attemptedAt    DateTime            @default(now())
}

model ExamAttemptAnswer {
  id         String        @id @default(cuid())
  attemptId  String
  attempt    ExamAttempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId String
  question   ExamQuestion  @relation(fields: [questionId], references: [id])
  choiceId   String?
  choice     ExamChoice?   @relation(fields: [choiceId], references: [id])
  isCorrect  Boolean       @default(false)

  @@unique([attemptId, questionId])
}

model Certification {
  id              String              @id @default(cuid())
  slug            String              @unique
  titleFr         String
  titleEn         String
  descriptionFr   String
  descriptionEn   String
  levelId         String
  level           CertificationLevel  @relation(fields: [levelId], references: [id])
  rank            Int                 @default(0)
  validityMonths  Int                 @default(24)
  courseId        String?
  course          Course?             @relation(fields: [courseId], references: [id])
  issued          CertificateIssued[]
  createdAt       DateTime            @default(now())
}

model CertificateIssued {
  id              String            @id @default(cuid())
  uniqueCode      String            @unique
  certificationId String
  certification   Certification     @relation(fields: [certificationId], references: [id])
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  status          CertificateStatus @default(VALID)
  issuedAt        DateTime          @default(now())
  expiresAt       DateTime?
  revokedAt       DateTime?
  revokedReason   String?
}

model Payment {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  amount      Decimal       @db.Decimal(10, 2)
  currency    String        @default("USD")
  provider    String
  status      PaymentStatus @default(PENDING)
  relatedType String
  relatedId   String
  createdAt   DateTime      @default(now())
}
